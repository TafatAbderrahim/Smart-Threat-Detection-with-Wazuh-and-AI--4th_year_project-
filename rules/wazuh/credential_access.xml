<!--
  ============================================================
  Rule File : credential_access.xml
  Author    : Teffat Abderahim
  Project   : Smart Threat Detection with Wazuh and AI
  Team      : ESI Sidi Bel Abbes — CyS 2SC — 2025/2026
  MITRE     : T1003.001 — OS Credential Dumping: LSASS Memory
  Tactic    : Credential Access
  IDs       : 100055–100059
  Attack    : Invoke-Mimikatz OR procdump -ma lsass.exe lsass.dmp
  ============================================================

  Detection Logic:
  LSASS (Local Security Authority Subsystem Service) holds all
  credential material in memory: NTLM hashes, Kerberos tickets,
  and in older configs plaintext passwords.

  Mimikatz accesses LSASS by opening a handle with:
    PROCESS_VM_READ (0x0010) — read process memory
    PROCESS_QUERY_INFORMATION (0x0400) — query process state

  Sysmon Event ID 10 (ProcessAccess) captures this exactly:
  which process opened which target, and with what access rights.
  ANY non-system process accessing lsass.exe with VM_READ is
  credential dumping — no legitimate exceptions.

  Common Mimikatz access masks:
    0x1010 = PROCESS_VM_READ | PROCESS_QUERY_LIMITED_INFORMATION
    0x1410 = above + PROCESS_QUERY_INFORMATION
    0x1fffff = full access (most aggressive tools)
-->

<group name="credential_dumping,lsass,mimikatz,windows">

  <!--
    RULE 100055 — Sysmon ID 10: any process opening lsass.exe
    Logic : Catches every ProcessAccess where TargetImage contains
            lsass.exe. Broad base rule — escalated by rules below.
    Level : 10
  -->
  <rule id="100055" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^10$</field>
    <match>lsass.exe</match>
    <description>LSASS Access: $(win.eventdata.sourceImage) opened handle to lsass.exe — possible credential dumping</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_dumping,lsass_access</group>
  </rule>

  <!--
    RULE 100056 — Critical: known dumping tool accessing lsass
    Logic : If the process accessing lsass is a known credential
            dumper → immediate critical alert. No threshold needed.
    Level : 15
  -->
  <rule id="100056" level="15">
    <if_matched_sid>100055</if_matched_sid>
    <match>(?i)(mimikatz|procdump|dumpert|nanodump|lsassy|wce\.exe|fgdump|sqldumper)</match>
    <description>Mimikatz DETECTED: $(win.eventdata.sourceImage) is dumping lsass.exe memory — IMMEDIATE RESPONSE REQUIRED</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_dumping,mimikatz,critical_severity</group>
  </rule>

  <!--
    RULE 100057 — Suspicious access mask on lsass
    Logic : GrantedAccess field shows what rights were granted.
            0x1010 and 0x1410 are the standard Mimikatz masks.
            0x1fffff = full process access — extremely suspicious.
    Level : 14
  -->
  <rule id="100057" level="14">
    <if_matched_sid>100055</if_matched_sid>
    <match>(?i)(0x1010|0x1410|0x1fffff|0x143a|0x0010)</match>
    <description>LSASS Memory Read with suspicious access mask $(win.eventdata.grantedAccess) — Mimikatz access pattern confirmed</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_dumping,lsass_access,high_severity</group>
  </rule>

  <!--
    RULE 100058 — Sysmon ID 1: process targeting lsass as argument
    Logic : procdump and similar tools take lsass as CLI argument.
            Catch the process creation before the dump completes.
    Level : 13
  -->
  <rule id="100058" level="13">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^1$</field>
    <match>(?i)(procdump|sqldumper|createdump|comsvcs)</match>
    <match>(?i)(lsass|lsass\.exe)</match>
    <description>LSASS Dump via Tool: $(win.eventdata.image) targeting lsass.exe — credential dump file being written to disk</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_dumping,lsass_dump</group>
  </rule>

  <!--
    RULE 100059 — Sysmon ID 11: lsass .dmp file created on disk
    Logic : If a .dmp file appears in a temp or attacker-controlled
            path after lsass access, the dump succeeded.
    Level : 14
  -->
  <rule id="100059" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^11$</field>
    <match>(?i)(lsass.*\.dmp|\.dmp)</match>
    <match>(?i)(\\Temp\\|\\Desktop\\|\\Downloads\\|\\Public\\)</match>
    <description>LSASS Dump File Created: $(win.eventdata.targetFilename) — credential dump file detected on disk</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_dumping,dump_file,high_severity</group>
  </rule>

</group>
